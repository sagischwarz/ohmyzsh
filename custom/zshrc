# Path to your oh-my-zsh installation.
export ZSH=$HOME/.oh-my-zsh

# Set name of the theme to load.
# Look in ~/.oh-my-zsh/themes/
# Optionally, if you set this to "random", it'll load a random theme each
# time that oh-my-zsh is loaded.
ZSH_THEME="sagischwarz"

# Aliases
alias u="brew upgrade && brew cleanup -s"
alias uu="u && npm update -g && rustup update && vim +PlugUpdate +PlugUpgrade +qall"
alias vim="nvim"
alias top="btop"
alias ag="ag --hidden --skip-vcs-ignores"
alias c="clear"
alias n="vim ~/Nextcloud/Notes/inbox.md"
alias h="cd ~ && c"
alias xclip="xclip -sel c"
alias r=reset

# Uncomment the following line to disable bi-weekly auto-update checks.
DISABLE_AUTO_UPDATE="true"
HOMEBREW_NO_ENV_HINTS=1

# Which plugins would you like to load? (plugins can be found in ~/.oh-my-zsh/plugins/*)
# Custom plugins may be added to ~/.oh-my-zsh/custom/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
plugins=(git zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# Fix slow paste (https://github.com/zsh-users/zsh-autosuggestions/issues/238)
pasteinit() {
  OLD_SELF_INSERT=${${(s.:.)widgets[self-insert]}[2,3]}
  zle -N self-insert url-quote-magic # I wonder if you'd need `.url-quote-magic`?
}

pastefinish() {
  zle -N self-insert $OLD_SELF_INSERT
}
zstyle :bracketed-paste-magic paste-init pasteinit
zstyle :bracketed-paste-magic paste-finish pastefinish

# fzf
source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
source /opt/homebrew/opt/fzf/shell/completion.zsh
export FZF_DEFAULT_COMMAND="fd --type f --hidden --no-ignore --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --no-ignore --exclude .git"
_fzf_compgen_path() {
  fd --hidden --follow --exclude ".git" . "$1"
}
_fzf_compgen_dir() {
  fd --type d --hidden --follow --exclude ".git" . "$1"
}
bindkey "©" fzf-cd-widget

# User configuration
export GOPATH=$HOME/Code/Go
export PIPENV_VENV_IN_PROJECT=true

# Improve history
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt HIST_BEEP

# Evals and exports
export TERM="xterm-256color"

export PATH="${PATH}:$HOME/.local/bin"
export PATH="${PATH}:$(ruby -e 'puts Gem.user_dir')/bin"
export PATH="${PATH}:${GOPATH//://bin:}/bin"
export PATH="${PATH}:$HOME/.cargo/bin"
export PATH="${PATH}:$HOME/Library/Python/3.12/bin"

export EDITOR="nvim"
export VISUAL="nvim"

export MAKEFLAGS="-j $(sysctl -n hw.ncpu)"

# Install NPM stuff in home directory
# echo "prefix = $NPM_PACKAGES" >> ~/.npmrc
NPM_PACKAGES="$HOME/.npm-packages"
PATH="$NPM_PACKAGES/bin:$PATH"
MANPATH="$NPM_PACKAGES/share/man:$(manpath)"
NODE_PATH="$NPM_PACKAGES/lib/node_modules:$NODE_PATH"

